# Copy this file to .env and fill in your FREE keys.
# These are read by server.js on the SERVER — they are never sent to the browser.

# Live equity/ETF quotes (real-time US stocks & ETFs)
# Get a free key: https://finnhub.io/register
FINNHUB_API_KEY=

# Macro: VIX, yields, credit spreads (daily)
# Get a free key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
